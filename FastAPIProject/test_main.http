# Test your FastAPI endpoints

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/hello/User
Accept: application/json

###
@token = replace-with-login-token
@email = user@example.com
@password = replace-with-password

GET http://127.0.0.1:8000/auth/code?email={{email}}
Accept: application/json

###
POST http://127.0.0.1:8000/auth/register
Accept: application/json
Content-Type: application/json

{
  "email": "{{email}}",
  "username": "demo_user",
  "password": "{{password}}",
  "confirm_password": "{{password}}",
  "code": "123456"
}


###
POST http://127.0.0.1:8000/auth/login
Accept: application/json
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

###
POST http://127.0.0.1:8000/names/get_names
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "category": "宠物名",
  "length": "两字",
  "gender": "不限",
  "other": "是一只非常调皮的金毛犬，毛发金黄，希望名字听起来活泼可爱"
}

###
POST http://127.0.0.1:8000/names/get_names
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "category": "企业名",
  "other": "我们要推出一款全新的AI智能硬件，希望能起个好名字"
}

###
POST http://127.0.0.1:8000/names/generate
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "category": "企业名",
  "other": "我们要推出一款全新的AI智能硬件，希望能起个好名字"
}

###
POST http://127.0.0.1:8000/names/feedback
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "thread_id": "fefb4e89-93d6-4385-be85-457f655ff35c",
  "category": "企业名",
  "feedback": "我喜欢上一轮生成的‘熠新’这个名字。请保留它，并以此为基调，把其他4个名字的第一个字全部换成五行属‘火’的字。"
}






###
POST http://127.0.0.1:8000/knowledge/upload
Content-Type: multipart/form-data; boundary=WebAppBoundary
Authorization: Bearer {{token}}

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="company_rules.txt"
Content-Type: text/plain

< ./company_rules.txt
--WebAppBoundary--

### 第一轮：首次起名
POST http://127.0.0.1:8000/names/generate
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "category": "企业名",
  "surname": "",
  "length": "五个字以上",
  "gender": "不限",
  "other": "一家做环保新材料的初创公司",
  "exclude": []
}
